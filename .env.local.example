# ====== Supabase ======
# Project URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
# anon public key (Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# service_role key (Settings > API > Project API keys > service_role) -> SOLO servidor, NUNCA exponer
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ====== Sesión ======
# Secreto para firmar el JWT de sesión. Genera uno con: openssl rand -base64 32
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
